#!/usr/bin/env python3


# Can be removed after installing (pip install -e .)
import sys
from pathlib import Path
sys.path.append(str(Path(__file__).resolve().parents[1]))


from pydm import ServiceContainer

from src.nonet_movie.infrastructure.boot import boot
from src.nonet_movie.infrastructure.console.console_command_handler import ConsoleCommandHandler


def main() -> None:
    boot()

    ServiceContainer.get_instance().get_service(ConsoleCommandHandler).handle()

if __name__ == '__main__':
    main()
