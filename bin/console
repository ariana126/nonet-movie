#!/usr/bin/env python3


# Can be removed after installing (pip install -e .)
import sys
from pathlib import Path
sys.path.append(str(Path(__file__).resolve().parents[1]))


from pydm import ServiceContainer

from src.nonet_movie.infrastructure.boot import boot
from src.nonet_movie.infrastructure.console.command import ConsoleCommandHandler


def main() -> None:
    boot()

    command, args = parse_argv()
    ServiceContainer.get_instance().get_service(ConsoleCommandHandler).handle(command, args)

def parse_argv():
    args = sys.argv
    if 1 == len(args):
        raise RuntimeError('Command name must be specified.')
    return str(args[1]), args[2:]


if __name__ == '__main__':
    main()
